#ifndef __XMC_LCD_H
#define __XMC_LCD_H

#ifdef __cplusplus
extern "C" {
#endif

#include "at32f403a_407.h"
#include "wk_system.h"
#include <stdio.h>
/** @addtogroup AT32F407_periph_examples
  * @{
  */

/** @addtogroup 407_XMC_lcd_8bit
  * @{
  */




/** @defgroup XMC_lcd_8bit_address_of_data_and_command
  * @{
  */

/* the address of write data & command (xmc_a0) */
#define  XMC_LCD_COMMAND                 0x6c000000
#define  XMC_LCD_DATA                    0x6c000001

/**
  * @}
  */

/** @defgroup XMC_lcd_8bit_reset_line
  * @{
  */

/* the lcd reset line */
#define LCD_RESET_HIGH                   gpio_bits_set(GPIOA,GPIO_PINS_6)
#define LCD_RESET_LOW                    gpio_bits_reset(GPIOA,GPIO_PINS_6)

/**
  * @}
  */

/* 颜色定义 */
#define WHITE                            0xFFFF
#define BLACK                            0x0000
#define BLUE                             0x001F
#define BRED                             0xF81F
#define GRED                             0xFFE0
#define GBLUE                            0x07FF
#define RED                              0xF800
#define MAGENTA                          0xF81F
#define GREEN                            0x07E0
#define CYAN                             0x7FFF
#define YELLOW                           0xFFE0
#define BROWN                            0xBC40
#define BRRED                            0xFC07
#define GRAY                             0x8430

/* 显示方向定义 */ 
typedef enum
{
    LCD_DIRECTION_PORTRAIT = 0,     // 竖屏
    LCD_DIRECTION_LANDSCAPE = 1     // 横屏
} LCD_DirectionType;

/* LCD信息结构体 */
typedef struct
{
    uint16_t width;                 // 屏幕宽度
    uint16_t height;                // 屏幕高度
    uint16_t id;                    // LCD芯片ID
    LCD_DirectionType direction;    // 当前显示方向
    uint8_t scan_mode;              // 当前扫描模式
} LCD_InfoType;


typedef enum {
    FONT_12X6,    // ascii_1206[][12]
    FONT_16X8,    // ascii_1608[][16]
    FONT_24X12,   // ascii_2412[][48]
    FONT_32X16,   // ascii_3216[][64]
    FONT_40X20    // ascii_4020[][120]
} AsciiFontSize;

/* 屏幕尺寸定义 */
#define LCD_PORTRAIT_WIDTH   320
#define LCD_PORTRAIT_HEIGHT  480
#define LCD_LANDSCAPE_WIDTH  480
#define LCD_LANDSCAPE_HEIGHT 320

/* 显示方向宏 (二选一) */
#define LCD_DISPLAY_PORTRAIT             0   // 竖屏模式 (320x480)
#define LCD_DISPLAY_LANDSCAPE            1   // 横屏模式 (480x320)

/* 扫描方向宏 (八选一) - 基于ILI9488的0x36寄存器设置 */
#define LCD_SCAN_LR_TB                   0x00  // 从左到右,从上到下
#define LCD_SCAN_LR_BT                   0x80  // 从左到右,从下到上 (MY=1)
#define LCD_SCAN_RL_TB                   0x40  // 从右到左,从上到下 (MX=1)
#define LCD_SCAN_RL_BT                   0xC0  // 从右到左,从下到上 (MY=1, MX=1)
#define LCD_SCAN_TB_LR                   0x20  // 从上到下,从左到右 (MV=1)
#define LCD_SCAN_TB_RL                   0x60  // 从上到下,从右到左 (MV=1, MX=1)
#define LCD_SCAN_BT_LR                   0xA0  // 从下到上,从左到右 (MV=1, MY=1)
#define LCD_SCAN_BT_RL                   0xE0  // 从下到上,从右到左 (MV=1, MY=1, MX=1)

/* 常用组合 (快捷方式) */
#define LCD_SCAN_NORMAL                  LCD_SCAN_LR_TB      // 正常扫描
#define LCD_SCAN_REVERSE                 LCD_SCAN_RL_BT      // 完全反转

/** @defgroup XMC_lcd_8bit_exported_functions
  * @{
  */

void xmc_init(void);
void lcd_init(void);
void lcd_wr_command(uint8_t command);
void lcd_wr_data(uint8_t data);
void lcd_set_block(uint16_t xstart, uint16_t ystart, uint16_t xend, uint16_t yend);
void lcd_write_one_point(uint16_t color);
void lcd_draw_point(uint16_t x, uint16_t y, uint16_t color);
void lcd_clear(uint16_t color);
void lcd_fill(uint16_t x1, uint16_t y1, uint16_t x2, uint16_t y2, uint16_t color);
void lcd_draw_line(uint16_t x_start, uint16_t y_start, uint16_t x_end, uint16_t y_end, uint16_t color);
uint8_t lcd_show_ascii_char(uint16_t x, uint16_t y, char ch, 
                           uint16_t color, uint16_t bg_color, AsciiFontSize font_size);
void lcd_show_ascii_string(uint16_t x, uint16_t y, const char *str,
                          uint16_t color, uint16_t bg_color, AsciiFontSize font_size);

uint16_t lcd_show_simple_number(uint16_t x, uint16_t y, int32_t num, 
                               uint16_t color, uint16_t bg_color, AsciiFontSize font_size);

uint16_t lcd_show_number(uint16_t x, uint16_t y, int32_t num, 
                        uint16_t color, uint16_t bg_color, AsciiFontSize font_size, uint8_t show_digits);
void lcd_display_number(void);
uint16_t lcd_read_id(void);

/* 新增函数：初始化显示方向和扫描方向 */
void lcd_set_display_mode(uint8_t display_mode, uint8_t scan_mode);

/* 新增函数：获取LCD信息 */
LCD_InfoType *LCD_GetInfo(void);

/**
  * @}
  */

/**
  * @}
  */

#ifdef __cplusplus
}

#endif

#endif